---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="About Us" lang="en">
  <Header currentPath="/about-us" />

  <main class="min-h-screen">
    <!-- Page Header -->
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">About Us</h1>
        <p class="text-cream-300 text-lg max-w-2xl">About the W.A. Silva Foundation</p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12">
          <h2 class="text-3xl font-bold text-ink-900 mb-4">W.A. Silva Foundation's Vision for Literary & Cultural Continuity</h2>
          <h4 class="text-xl font-semibold text-ink-700 mb-4">Vision Statement</h4>
          <ul class="list-disc list-inside space-y-2 text-ink-600">
            <li>Preserving the national contribution of W.A. Silva to language and literature</li>
            <li>Collecting and disseminating information about W.A. Silva</li>
            <li>Promoting and translating the books written by W.A. Silva into various languages</li>
            <li>Disseminating the above information through modern communication media such as radio, television, cinema and email</li>
            <li>Conducting research on W.A. Silva and his work</li>
            <li>Preserving "Silvermere" in Wellawatte, Colombo as a national treasure and establishing a language-literature library, language-literature museum, and an old Colombo information centre</li>
          </ul>
        </div>

        <div class="mb-12">
          <h2 class="text-3xl font-bold text-ink-900 mb-4">Our Mission</h2>
          <p class="text-ink-600 leading-relaxed text-lg">
            The main vision of the W.A. Silva Foundation is to promote his literary legacy so that the extraordinary national contributions made by W.A. Silva can be inherited eternally by future generations. This ensures that the enduring value of his creative works is passed on to the generations to come.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
