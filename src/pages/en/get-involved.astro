---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="Get Involved" lang="en">
  <Header currentPath="/en/get-involved" />

  <main class="min-h-screen">
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">Get Involved</h1>
        <p class="text-cream-300 text-lg max-w-2xl">Support the W.A. Silva Foundation</p>
      </div>
    </section>

    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12">
          <h2 class="text-3xl font-bold text-ink-900 mb-4">Support Our Mission</h2>
          <p class="text-ink-600 leading-relaxed text-lg mb-6">
            Your support helps us preserve and promote the literary legacy of W.A. Silva for future generations. There are many ways you can get involved.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
            <h3 class="text-xl font-bold text-ink-900 mb-3">Volunteer</h3>
            <p class="text-ink-600 mb-4">Join our team of volunteers and contribute to preserving Sri Lanka's literary heritage.</p>
            <a href="/en/contact-us" class="text-brand-600 hover:text-brand-700 font-medium">Contact us to learn more →</a>
          </div>
          <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
            <h3 class="text-xl font-bold text-ink-900 mb-3">Donate</h3>
            <p class="text-ink-600 mb-4">Your financial contributions help us maintain Silvermere, publish books, and run our programs.</p>
            <a href="/en/contact-us" class="text-brand-600 hover:text-brand-700 font-medium">Contact us to donate →</a>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
          <h3 class="text-2xl font-bold text-ink-900 mb-6">Contact Us</h3>
          <form id="contact-form" class="space-y-6" action="https://formspree.io/f/xgvavkqj" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-ink-700 mb-1">Name</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink-700 mb-1">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-ink-700 mb-1">Phone</label>
              <input type="tel" id="phone" name="phone"
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="interest" class="block text-sm font-medium text-ink-700 mb-1">I'm interested in</label>
              <select id="interest" name="interest" required
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors bg-white">
                <option value="">Select an option</option>
                <option value="volunteer">Volunteering</option>
                <option value="donation">Making a Donation</option>
                <option value="venue">Venue Hire</option>
                <option value="partnership">Partnership / Collaboration</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-ink-700 mb-1">Message</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors"></textarea>
            </div>
            <button type="submit"
              class="w-full sm:w-auto px-8 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg transition-colors">
              Send
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
