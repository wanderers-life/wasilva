---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="Contact Us" lang="en">
  <Header currentPath="/contact-us" />

  <main class="min-h-screen">
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">Contact Us</h1>
        <p class="text-cream-300 text-lg max-w-2xl">Get in touch with the W.A. Silva Foundation</p>
      </div>
    </section>

    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-6">Get in Touch</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink-900">Address</h3>
                  <p class="text-ink-600">No. 126, W.A. Silva Mawatha,<br />Wellawatte, Colombo 6,<br />Sri Lanka</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink-900">Phone</h3>
                  <p class="text-ink-600">+94 712 748 174</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink-900">Email</h3>
                  <p class="text-ink-600">info@wasilva.org</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-6">Send a Message</h2>
            <form id="contact-form" class="space-y-6" action="https://formspree.io/f/xgvavkqj" method="POST">
              <div>
                <label for="name" class="block text-sm font-medium text-ink-700 mb-1">Name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-ink-700 mb-1">Email</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-ink-700 mb-1">Message</label>
                <textarea id="message" name="message" rows="5" required
                  class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors"></textarea>
              </div>
              <button type="submit"
                class="w-full sm:w-auto px-8 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg transition-colors">
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
