---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="Venue Hire" lang="en">
  <Header currentPath="/en/venue-hire" />

  <main class="min-h-screen">
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">Venue Hire</h1>
        <p class="text-cream-300 text-lg max-w-2xl">Book our spaces for your next event</p>
      </div>
    </section>

    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12">
          <h2 class="text-3xl font-bold text-ink-900 mb-4">Silvermere — A Historic Venue</h2>
          <p class="text-ink-600 leading-relaxed text-lg mb-6">
            Silvermere, the historic residence of W.A. Silva in Wellawatte, Colombo, is available for hire for cultural events, literary gatherings, workshops, and private functions. Set in a tranquil environment, it provides a unique atmosphere steeped in Sri Lanka's literary history.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
            <h3 class="text-xl font-bold text-ink-900 mb-3">Main Hall</h3>
            <p class="text-ink-600 mb-4">Capacity: up to 100 guests. Ideal for seminars, book launches, and cultural performances.</p>
          </div>
          <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
            <h3 class="text-xl font-bold text-ink-900 mb-3">Library Room</h3>
            <p class="text-ink-600 mb-4">Capacity: up to 30 guests. Perfect for intimate meetings, workshops, and reading sessions.</p>
          </div>
          <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
            <h3 class="text-xl font-bold text-ink-900 mb-3">Garden Area</h3>
            <p class="text-ink-600 mb-4">Capacity: up to 150 guests. Beautiful outdoor space for receptions and gatherings.</p>
          </div>
          <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
            <h3 class="text-xl font-bold text-ink-900 mb-3">Full Venue</h3>
            <p class="text-ink-600 mb-4">Capacity: up to 250 guests. Exclusive use of the entire Silvermere property.</p>
          </div>
        </div>

        <!-- Booking Form -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
          <h3 class="text-2xl font-bold text-ink-900 mb-6">Booking Enquiry</h3>
          <form id="venue-form" class="space-y-6" action="https://formspree.io/f/xgvavkqj" method="POST">
            <input type="hidden" name="_subject" value="Venue Hire Enquiry" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-ink-700 mb-1">Name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-ink-700 mb-1">Email</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
              </div>
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-ink-700 mb-1">Phone</label>
              <input type="tel" id="phone" name="phone"
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="event-type" class="block text-sm font-medium text-ink-700 mb-1">Event Type</label>
              <select id="event-type" name="event-type" required
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors bg-white">
                <option value="">Select event type</option>
                <option value="seminar">Seminar / Workshop</option>
                <option value="book-launch">Book Launch</option>
                <option value="cultural">Cultural Event</option>
                <option value="private">Private Function</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-ink-700 mb-1">Additional Details</label>
              <textarea id="message" name="message" rows="5"
                class="w-full px-4 py-3 rounded-lg border border-ink-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-colors"></textarea>
            </div>
            <button type="submit"
              class="w-full sm:w-auto px-8 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg transition-colors">
              Send Enquiry
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
