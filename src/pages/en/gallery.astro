---

<BaseLayout title="Gallery" lang="en">
  <Header currentPath="/en/gallery" />

  <main class="min-h-screen">
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">Gallery</h1>
        <p class="text-cream-300 text-lg max-w-2xl">Photo collection of the W.A. Silva Foundation</p>
      </div>
    </section>

    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <GalleryGrid images={galleryImages} />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
