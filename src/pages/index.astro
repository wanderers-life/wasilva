---

<BaseLayout title="මුල් පිටුව">
  <Header currentPath="/" />

  <!-- A. Hero Carousel -->
  <HeroCarousel />

  <!-- B. Programs Card Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-4">අපගේ වැඩසටහන්</h2>
        <p class="text-ink-600 max-w-2xl mx-auto">
          ඩබ්ලිව්. ඒ. සිල්වා පදනමේ ප්‍රධාන වැඩසටහන් පහ
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
        {programs.map((program) => (
          <ProgramCard
            image={program.image}
            title={program.title}
            description={program.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- C. Vision Block -->
  <section class="py-16 lg:py-24 bg-cream-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
