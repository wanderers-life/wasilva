---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="අපව සම්බන්ධ කරගන්න">
  <Header currentPath="/contact-us" />

  <main class="min-h-screen">
    <!-- Page Header -->
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">අපව සම්බන්ධ කරගන්න</h1>
        <p class="text-cream-300 text-lg max-w-2xl">අප සමඟ සම්බන්ධ වන්න</p>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-6">අපගේ ලිපිනය</h2>
            <div class="space-y-4 text-ink-700">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 mt-0.5 shrink-0 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="font-semibold">ලිපිනය</p>
                  <p>
                    අංක 126, ඩබ්ලිව්. ඒ. සිල්වා මාවත,<br />
                    වැල්ලවත්ත, කොළඹ 6,<br />
                    ශ්‍රී ලංකාව
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 shrink-0 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <p class="font-semibold">දුරකථන</p>
                  <p>+94 712 748 174</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 shrink-0 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="font-semibold">විද්‍යුත් තැපෑල</p>
                  <a href="mailto:info@wasilva.org" class="text-brand-600 hover:text-brand-700">info@wasilva.org</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form Placeholder -->
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-6">අපට පණිවිඩයක් එවන්න</h2>
            <div class="bg-white rounded-xl p-8 shadow-sm border border-ink-100">
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-ink-700 mb-1">ඔබගේ නම</label>
                  <input
                    type="text"
                    class="w-full px-4 py-2.5 border border-ink-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                    placeholder="ඔබගේ නම"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-ink-700 mb-1">විද්‍යුත් තැපෑල</label>
                  <input
                    type="email"
                    class="w-full px-4 py-2.5 border border-ink-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                    placeholder="ඔබගේ ඊ-මේල් ලිපිනය"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-ink-700 mb-1">පණිවිඩය</label>
                  <textarea
                    rows="5"
                    class="w-full px-4 py-2.5 border border-ink-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                    placeholder="ඔබගේ පණිවිඩය..."
                  ></textarea>
                </div>
                <button
                  class="w-full px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg transition-colors"
                >
                  [CONTENT PLACEHOLDER — form not yet functional]
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
