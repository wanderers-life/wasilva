---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="අපි ගැන">
  <Header currentPath="/about-us" />

  <main class="min-h-screen">
    <!-- Page Header -->
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">අපි ගැන</h1>
        <p class="text-cream-300 text-lg max-w-2xl">ඩබ්ලිව්. ඒ. සිල්වා පදනම පිළිබඳ තොරතුරු</p>
      </div>
    </section>

    <!-- Content Placeholder -->
    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-amber-50 border-l-4 border-brand-500 p-6 rounded-r-lg">
          <p class="text-ink-700 font-medium">
            [CONTENT PLACEHOLDER — paste real copy here]
          </p>
          <p class="text-ink-500 mt-2 text-sm">
            This page needs the full about-us content from the live site. Open
            https://www.wasilva.org/about-us in a browser, copy the rendered text,
            and paste it here.
          </p>
        </div>

        <!-- Suggested structure -->
        <div class="mt-12 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-4">ඉතිහාසය</h2>
            <p class="text-ink-600">[CONTENT PLACEHOLDER — foundation history]</p>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-4">අපගේ කාර්යය</h2>
            <p class="text-ink-600">[CONTENT PLACEHOLDER — mission and work]</p>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-ink-900 mb-4">කණ්ඩායම</h2>
            <p class="text-ink-600">[CONTENT PLACEHOLDER — team members]</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
