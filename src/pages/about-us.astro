---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="අපි ගැන">
  <Header currentPath="/about-us" />

  <main class="min-h-screen">
    <!-- Page Header -->
    <section class="bg-ink-900 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">අපි ගැන</h1>
        <p class="text-cream-300 text-lg max-w-2xl">ඩබ්ලිව්. ඒ. සිල්වා පදනම පිළිබඳ තොරතුරු</p>
      </div>
    </section>

    <!-- Content Placeholder -->
    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
          <div class="mb-12">
            <h2 class="text-3xl font-bold text-ink-900 mb-4">ඩබ්ලිව්. ඒ. සිල්වා පදනමේ සාහිත්‍ය හා සංස්කෘතික අඛණ්ඩතාවයට ඇති දැක්ම</h2>
            <h4 class="text-xl font-semibold text-ink-700 mb-4">දැක්ම ප්‍රකාශය</h4>
            <ul class="list-disc list-inside space-y-2 text-ink-600">
              <li>ඩබ්ල්ව්. එ්. සිල්වා ගෙන් භාෂාවට හා සාහිත්‍යයට සිදුවූ ජාතික සේවාව තව දුරටත් ව්‍යාප්ත කිරීම</li>
              <li>ඩබ්ල්ව්. එ්. සිල්වා පිළිබඳ තොරතුරු එක් රැස් කිරීම.</li>
              <li>ඩබ්ල්ව්. එ්. සිල්වා විසින් රචිත පොත් පත් තවදුරටත් ප‍්‍රචාරය කිරීම හා විවිධ භාෂාවලට පරිවර්තනය කිරීම.</li>
              <li>ඉහත සඳහන් තොරතුරු ගුවන් විදුලි, රූපවාහිනී, සිනමා සහ විද්‍යුත් තැපැල් ආදී නවීන සන්නිවේදන මාධ්‍ය ඔස්සේ ප‍්‍රචාරය කිරීම.</li>
              <li>ඩබ්ල්ව්. එ්. සිල්වා සහ ඔහු විසින් කරන ලද මෙහෙය පිළිබඳ පර්යේෂණ සිදු කිරීම.</li>
              <li>ඩබ්ල්ව්. එ්. සිල්වා ජීවත් වූ කොළඹ වැල්ලෙවත්තේ පිහිටි ”සිල්වර් මියර්” නම් නිවස ජාතික වස්තුවක් වශයෙන් සංරක්‍ෂණය කිරීම හා එ මගින් භාෂා-සාහිත්‍ය පුස්ථකාලයක්, භාෂා-සාහිත්‍ය කෞතුකාගාරයක් හා ඉපැරැුණි කොළඹ පිළිබඳ තොරතුරු කේන්ද්‍රයක් ස්ථාපිත කිරිම.</li>
            </ul>
          </div>

          <div class="mb-12">
            <h2 class="text-3xl font-bold text-ink-900 mb-4">අපගේ මෙහෙවර</h2>
            <p class="text-ink-600 leading-relaxed text-lg">
              ඩබ්ලිව්. ඒ. සිල්වා පදනමේ ප්‍රධාන දැක්ම වන්නේ ඩබ්ලිව්. ඒ. සිල්වා විසින් කළ අති විශිෂ්ට ජාතික දායකත්වයන් අනාගත පරපුරට සදාකාලිකව උරුමකර ගැනීමට ඔහුගේ සාහිත්‍ය උරුමය ප්‍රවර්ධනය කිරීමයි. එමඟින් ඔහුගේ නිර්මාණාත්මක කෘතීන්හි ස්ථායි වටිනාකම ලබන්නා වන පරපුරට යැවීම සහතික කිරීමයි.
            </p>
          </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
