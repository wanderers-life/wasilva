---
import { url } from "../lib/url";

const slidesSi = [
  {
    eyebrow: "මුද්‍රණ සංග්‍රහ මැදුර සහ වර්ණලේඛන එකතුව",
    headline:
      "මැදුරේ ප්‍රදර්ශනයට පත් කර ඇත්තේ සම්පූර්ණ සම්ප්‍රදායික ලිපි මැටි මුද්‍රණ යන්ත්‍රයක් සහ ගස් හා ලෝහ අකුරු එකතුවක් වේ.",
    image: "/images/1748858685.jpg",
  },
  {
    eyebrow: "පොත්සාලාව සහ සංරක්ෂණාගාරය",
    headline:
      "ඩබ්ලිව්. ඒ. සිල්වා මැදුර ශ්‍රී ලංකා වර්ණලේඛන ආයතනයට වාසස්ථානය වන අතර, දේශීය භාෂා, ලිපි හා සාහිත්‍ය පිළිබඳ පොත් සහ සම්පත් සංරක්ෂණාගාරයක් ලෙස ක්‍රියා කරයි.",
    image: "/images/1748859875.jpg",
  },
  {
    eyebrow: "වැඩමුලු සහ සිදුවීම්",
    headline:
      "ඩබ්ලිව්. ඒ. සිල්වා මැදුර මුද්‍රණය, ලිපි, භාෂා හා සාහිත්‍ය සම්බන්ධ වැඩමුලු, සංවාද සහ සිදුවීම් සංවිධානය කරයි.",
    image: "/images/1748861223.jpg",
  },
];

const slidesEn = [
  {
    eyebrow: "Print Collection & Typography",
    headline:
      "A complete traditional letterpress printing machine and a collection of wooden and metal typefaces are on display at the mansion.",
    image: "/images/1748858685.jpg",
  },
  {
    eyebrow: "Library & Archive",
    headline:
      "The W.A. Silva mansion is home to the Sri Lanka Institute of Typography and serves as an archive of books and resources on indigenous languages, scripts and literature.",
    image: "/images/1748859875.jpg",
  },
  {
    eyebrow: "Workshops & Events",
    headline:
      "The W.A. Silva mansion organizes workshops, discussions and events related to printing, scripts, language and literature.",
    image: "/images/1748861223.jpg",
  },
];

const { lang = "si" } = Astro.props;
const slides = lang === "en" ? slidesEn : slidesSi;
const isEn = lang === "en";
---

<div
  id="hero-carousel"
  class="relative w-full overflow-hidden bg-ink-900"
  data-current="0"
>
  <!-- Slides -->
  <div class="relative h-[60vh] min-h-[400px] sm:h-[70vh] lg:h-[80vh]">
    {slides.map((slide, index) => (
      <div
        class="slide absolute inset-0 transition-opacity duration-700 ease-in-out"
        class:list={{ "opacity-0": index !== 0, "opacity-100": index === 0 }}
      >
        <!-- Background Image -->
        <div
          class="absolute inset-0 bg-cover bg-center"
          style={`background-image: url('${url(slide.image)}')`}
        ></div>
        <!-- Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-ink-950/80 via-ink-950/40 to-ink-950/20"></div>
        <!-- Content -->
        <div class="relative h-full flex items-center">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
            <div class="w-full">
              <span class="inline-block text-brand-400 text-[10px] sm:text-xs font-semibold tracking-wide uppercase mb-1">
                {slide.eyebrow}
              </span>
              <h1 class="text-white text-[9px] sm:text-[10px] font-bold leading-tight mb-6 animate-hero-headline max-w-none whitespace-normal" style="transform: scale(0.4); transform-origin: top left;">
                {slide.headline}
              </h1>
              <div class="flex flex-wrap gap-3">
                <a
                  href={url(isEn ? "/en/about-us" : "/about-us")}
                  class="inline-flex items-center px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg transition-colors text-sm sm:text-base"
                >
                  {isEn ? "Read More" : "තවදුරටත් කියවන්න"}
                </a>
                <a
                  href={url(isEn ? "/en/get-involved" : "/get-involved")}
                  class="inline-flex items-center px-6 py-3 bg-white/20 hover:bg-white/30 text-white font-semibold rounded-lg backdrop-blur-sm transition-colors text-sm sm:text-base border border-white/30"
                >
                  {isEn ? "Get Involved" : "දැන් එක්වන්න"}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Prev/Next Arrows -->
  <button
    id="carousel-prev"
    class="absolute left-3 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white/20 hover:bg-white/30 text-white backdrop-blur-sm transition-colors"
    aria-label="Previous slide"
    type="button"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button
    id="carousel-next"
    class="absolute right-3 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white/20 hover:bg-white/30 text-white backdrop-blur-sm transition-colors"
    aria-label="Next slide"
    type="button"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Dot Indicators -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex gap-2">
    {slides.map((_, index) => (
      <button
        class="carousel-dot w-3 h-3 rounded-full transition-all"
        class:list={{
          "bg-brand-500 w-8": index === 0,
          "bg-white/50 hover:bg-white/70": index !== 0,
        }}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
        type="button"
      ></button>
    ))}
  </div>
</div>

<script>
  (function () {
    const container = document.getElementById("hero-carousel");
    if (!container) return;

    const slides = container.querySelectorAll(".slide");
    const dots = container.querySelectorAll(".carousel-dot");
    const prevBtn = document.getElementById("carousel-prev");
    const nextBtn = document.getElementById("carousel-next");
    let current = 0;
    let interval;

    function goTo(index) {
      slides.forEach((s, i) => {
        s.classList.toggle("opacity-0", i !== index);
        s.classList.toggle("opacity-100", i === index);
      });
      dots.forEach((d, i) => {
        d.classList.toggle("bg-brand-500", i === index);
        d.classList.toggle("w-8", i === index);
        d.classList.toggle("bg-white/50", i !== index);
        d.classList.toggle("hover:bg-white/70", i !== index);
      });
      current = index;
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    function prev() {
      goTo((current - 1 + slides.length) % slides.length);
    }

    function resetInterval() {
      clearInterval(interval);
      interval = setInterval(next, 6000);
    }

    if (nextBtn) nextBtn.addEventListener("click", () => { next(); resetInterval(); });
    if (prevBtn) prevBtn.addEventListener("click", () => { prev(); resetInterval(); });
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        goTo(parseInt(dot.dataset.index));
        resetInterval();
      });
    });

    interval = setInterval(next, 6000);
  })();
</script>
