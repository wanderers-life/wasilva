---
export interface Props {
  class?: string;
}

const { class: additionalClass = "" } = Astro.props;
---

<div
  class={`type-block shrink-0 ${additionalClass}`}
>
</div>

<style>
  .type-block {
    width: 12px;
    height: 12px;
    background-color: var(--color-brass);
    border: 1px solid var(--color-sepia);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.15), inset 0 -1px 0 rgba(255, 255, 255, 0.3);
    display: inline-block;
  }
</style>