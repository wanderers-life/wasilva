---
export interface Props {
  thumbnail: string;
  title: string;
  excerpt: string;
  link: string;
}

const { thumbnail, title, excerpt, link } = Astro.props;
import { url } from "../lib/url";
---

<article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-ink-100">
  <div class="aspect-[16/9] overflow-hidden bg-ink-100 flex items-center justify-center">
    <img
      src={url(thumbnail)}
      alt={title}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>
  <div class="p-5">
    <h3 class="text-base font-bold text-ink-900 mb-2 leading-snug line-clamp-2">{title}</h3>
    <p class="text-ink-600 text-sm leading-relaxed mb-4 line-clamp-3">{excerpt}</p>
    <a
      href={url(link)}
      class="inline-flex items-center text-brand-600 hover:text-brand-700 font-medium text-sm transition-colors"
    >
      වැඩිදුර කියවන්න
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
