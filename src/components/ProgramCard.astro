---
export interface Props {
  image: string;
  title: string;
  description: string;
}

const { image, title, description } = Astro.props;
import { url } from "../lib/url";
---

<div class="group card-animate bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-ink-100">
  <div class="aspect-[16/10] overflow-hidden bg-ink-100 flex items-center justify-center">
    <img
      src={url(image)}
      alt={title}
      class="card-img w-full h-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="p-5">
    <h3 class="text-lg font-bold text-ink-900 mb-2 leading-snug">{title}</h3>
    <p class="text-ink-600 text-sm leading-relaxed">{description}</p>
  </div>
</div>
