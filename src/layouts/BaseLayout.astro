---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  lang?: "si" | "en";
}

const { title, description = "W.A. Silva Foundation — ඩබ්ලිව්. ඒ. සිල්වා පදනම", lang = "si" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Sinhala:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title} | W.A. Silva Foundation</title>
    <style>
      /* Ensure proper Sinhala conjunct/ligature rendering */
      * {
        font-feature-settings: "psts" 1, "liga" 1;
      }
    </style>
  </head>
  <body class="font-sinhala text-ink-900 bg-cream-50 antialiased">
    <slot />
  </body>
</html>
